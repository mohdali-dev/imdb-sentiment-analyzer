        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "✅ Training set: 25000 reviews\n",
            "   Positive: 12500, Negative: 12500\n",
            "\n",
            "Sample:\n",
            "Standard \"paint-by-numbers\" monster fare, filled with a bunch of routine plot devices from big-creature movies. It's like somebody had a deck of cards with plot ideas from other movies written on them...\n",
            "Label: 0\n"
          ]
        }
      ]
